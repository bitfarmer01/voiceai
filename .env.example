# Copy to .env.local and fill in. Never commit real values.

# VAPI — from the VAPI dashboard (https://dashboard.vapi.ai)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=

# Convex — populated by `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Admin console gate (env-gated /admin)
ADMIN_ACCESS_TOKEN=
